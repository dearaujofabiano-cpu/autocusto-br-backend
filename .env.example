# AutoCusto BR — Backend
# Renomeie para .env e preencha com seus valores reais
# NUNCA faça commit deste arquivo com dados reais

# Gemini (primário) — gratuito em aistudio.google.com/app/apikey
GEMINI_API_KEY=SUA_CHAVE_AQUI

# Groq (fallback 1) — gratuito em console.groq.com
GROQ_API_KEY=gsk_SUA_CHAVE_AQUI

# OpenRouter (fallback 2) — gratuito em openrouter.ai
OPENROUTER_API_KEY=sk-or-SUA_CHAVE_AQUI

# URL do frontend autorizado (ex: https://autocusto-br.vercel.app)
# Use * apenas para testes locais
ALLOWED_ORIGIN=*

# Porta local
PORT=3000
