{
  "version": 2,
  "name": "autocusto-br-backend",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key",
    "ALLOWED_ORIGIN": "@allowed_origin"
  }
}
